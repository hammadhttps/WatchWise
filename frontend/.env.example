VITE_TMDB_API_URL=https://api.themoviedb.org/3
VITE_TMDB_API_TOKEN=your-tmdb-read-access-token

# Only needed in production, where the frontend and backend are on
# different domains. Leave unset for local dev (Vite proxies /api
# and /socket.io to localhost:5000).
VITE_API_URL=https://your-backend.onrender.com
